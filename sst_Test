#!/usr/bin/env python3

"""
双侧单样本 t 检验（single-sample t-test）
目标：检验样本均值是否与基线 TDN 的 mu0=52.3 有显著差异。
"""

import math
from statistics import mean, stdev

from scipy import stats


def main() -> None:
	mu0 = 52.3
	x = [52.88, 52.67, 52.83, 52.62, 52.64]
	seeds = [0, 1, 42, 123, 1024]
	alpha = 0.005

	n = len(x)
	x_bar = mean(x)
	s = stdev(x)  # 样本标准差（分母 n-1）
	t_stat_manual = (x_bar - mu0) / (s / math.sqrt(n))

	# 双侧单样本 t 检验
	t_stat_scipy, p_value = stats.ttest_1samp(x, popmean=mu0, alternative="two-sided")

	print("=== SST (Single-Sample t-test), Two-Sided ===")
	print(f"seeds                = {seeds}")
	print(f"sample x             = {x}")
	print(f"baseline mu0         = {mu0}")
	print(f"n                    = {n}")
	print(f"sample mean          = {x_bar:.6f}")
	print(f"sample std (n-1)     = {s:.6f}")
	print(f"df                   = {n - 1}")
	print(f"t-stat (manual)      = {t_stat_manual:.6f}")
	print(f"t-stat (scipy)       = {t_stat_scipy:.6f}")
	print(f"two-sided p-value    = {p_value:.12f}")
	print(f"threshold alpha      = {alpha}")
	print(f"p-value < {alpha}?   = {p_value < alpha}")

	if p_value < alpha:
		print("结论：在 alpha=0.005 下，拒绝 H0（均值与 52.3 存在显著差异）。")
	else:
		print("结论：在 alpha=0.005 下，不能拒绝 H0。")


if __name__ == "__main__":
	main()
